{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "patient_email": {
      "type": "string",
      "description": "Email of the patient"
    },
    "doctor_email": {
      "type": "string",
      "description": "Email of the doctor"
    },
    "patient_name": {
      "type": "string"
    },
    "doctor_name": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active"
    }
  },
  "required": [
    "patient_email",
    "doctor_email"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "data.doctor_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "data.doctor_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
