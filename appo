{
  "name": "Appointment",
  "type": "object",
  "properties": {
    "patient_email": {
      "type": "string"
    },
    "doctor_email": {
      "type": "string"
    },
    "patient_name": {
      "type": "string"
    },
    "doctor_name": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": [
        "video_call",
        "chat",
        "in_person"
      ],
      "default": "video_call"
    },
    "status": {
      "type": "string",
      "enum": [
        "scheduled",
        "in_progress",
        "completed",
        "cancelled"
      ],
      "default": "scheduled"
    },
    "notes": {
      "type": "string"
    },
    "room_id": {
      "type": "string"
    }
  },
  "required": [
    "patient_email",
    "doctor_email",
    "date"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "data.doctor_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.patient_email": "{{user.email}}"
        },
        {
          "data.doctor_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
