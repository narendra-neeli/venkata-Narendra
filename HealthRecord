        "mild",
        "moderate",
        "severe",
        "critical"
      ],
      "default": "mild"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "monitoring",
        "improving",
        "resolved"
      ],
      "default": "active"
    },
    "blood_pressure_systolic": {
      "type": "number"
    },
    "blood_pressure_diastolic": {
      "type": "number"
    },
    "heart_rate": {
      "type": "number"
    },
    "temperature": {
      "type": "number"
    },
    "blood_sugar": {
      "type": "number"
    },
    "oxygen_saturation": {
      "type": "number"
    },
    "weight": {
      "type": "number"
    },
    "notes": {
      "type": "string"
    },
    "recorded_date": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "patient_email",
    "condition"
  ],
